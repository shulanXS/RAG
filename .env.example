# =============================================================================
# .env.example — 环境变量示例
# 复制为 .env 后填写实际值
# =============================================================================

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Embedding Providers
VOYAGE_API_KEY=...
COHERE_API_KEY=...

# Vector Database
QDRANT_URL=http://localhost:6333

# Semantic Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Authentication (P1.4 强校验，必须设置)
# =============================================================================
# JWT 签名密钥（最少 32 字符随机串）。生产环境必须使用长随机串，丢失即 token 全失效。
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-me-with-a-random-64-char-string

# Password 加密的 pepper（与 bcrypt salt 不同的额外 secret）。
# 与 JWT_SECRET_KEY 独立管理，防止一处泄露导致两处都泄露。
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_PEPPER=replace-me-with-another-random-32-char-string

# =============================================================================
# Observability (P1.5 启用)
# =============================================================================
# OpenTelemetry OTLP endpoint (e.g. Jaeger 4317, Tempo 4317, Honeycomb).
# 留空则降级为 console exporter，仅用于本地调试。
OTLP_ENDPOINT=http://jaeger:4317
