  "liveNow": false,
  "panels": [
    {
      "title": "RAG Retrieval Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(rag_retrieval_latency_seconds_bucket{stage=\"total\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Cache Hit Rate",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(rag_cache_hit_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(rag_cache_hit_total[5m])), 0.001)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "LLM Tokens / sec",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(rag_llm_tokens_total[5m])) by (model, type)",
          "legendFormat": "{{model}} / {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 4, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(rag_errors_total[5m])) by (error_type, component)",
          "legendFormat": "{{component}} / {{error_type}}",
          "refId": "A"
        }
      ]
    }
  ],
